{
  "name": "pa-4-business",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:quality": "vitest run --config vitest.quality.config.ts",
    "test:quality:smoke": "QUALITY_SAMPLES=1 vitest run --config vitest.quality.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:apply": "tsx scripts/apply-all-migrations.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src/skills/**/*.ts",
    "seed": "tsx scripts/seed.ts",
    "provision": "tsx scripts/provision.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/genai": "^1.50.1",
    "bullmq": "^5.0.0",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.41.0",
    "fastify": "^5.0.0",
    "googleapis": "^144.0.0",
    "ioredis": "^5.0.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^10.2.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^2.0.0"
  }
}
