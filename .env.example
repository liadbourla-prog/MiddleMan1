# Database
DATABASE_URL=postgres://user:password@localhost:5432/pa4business

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Google Calendar OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Vertex AI (LLM) — no API key needed; uses GCP Application Default Credentials
GOOGLE_CLOUD_PROJECT=
VERTEX_AI_LOCATION=us-central1

# Server
PORT=3000
NODE_ENV=development

# Session config
SESSION_EXPIRY_MINUTES=30
HOLD_EXPIRY_MINUTES=15

# Meta app credentials (used for Embedded Signup OAuth flow)
META_APP_ID=
META_APP_SECRET=

# Provider (central) WhatsApp number — routes Step 0 business onboarding
PROVIDER_WA_NUMBER=
PROVIDER_WA_PHONE_NUMBER_ID=
PROVIDER_WA_ACCESS_TOKEN=

# Operator phone — messages from this number on PROVIDER_WA_NUMBER are routed to the
# admin console instead of the registration flow. Set to the platform owner's personal number.
OPERATOR_PHONE=+972543503704

# Public base URL (used for OAuth redirects and import token links)
PUBLIC_BASE_URL=http://localhost:3000

# Website builder (S4 skill)
# In dev: SITE_BUILDER_URL=http://localhost:3000 (self-referential — same Fastify process)
# In prod Cloud Run: set to the service's own URL
SITE_BUILDER_URL=http://localhost:3000
SITE_BUILDER_SECRET=changeme-secret-token

# GCS preview hosting for website-builder
# PREVIEW_BUCKET — the GCS bucket name (must have allUsers:objectViewer for public access)
# PREVIEW_BUCKET_URL — public base URL for the bucket (e.g. https://storage.googleapis.com/{bucket})
PREVIEW_BUCKET=pa4b-preview-sites
PREVIEW_BUCKET_URL=https://storage.googleapis.com/pa4b-preview-sites

# GATE-1: domain registrar/hosting integration
# Set to "true" once the domain provider is configured to unlock steps 7–8 of website-builder
GATE_1_RESOLVED=false
